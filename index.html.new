<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Home Nerd | Mach dein Zuhause smart</title>
<meta name="description" content="Tutorials, Reviews & Automationen für dein Smart Home.">
<link rel="icon" href="assets/images/favicon.png">
<link rel="manifest" href="manifest.json">

<style>
/* System Fonts - funktionieren bei file:// UND http:// */
:root {
--nerd-bg: #091021;
--nerd-card: #0d1629;
--nerd-border: #1a2847;
--nerd-text: #fbfcfc;
--nerd-muted: #8b9bb3;
--accent: #3b82f6;
--accent-hover: #60a5fa;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

/* SYSTEM UI FONTS - funktionieren immer, egal ob file:// oder http:// */
body {
font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
background: var(--nerd-bg);
color: var(--nerd-text);
line-height: 1.6;
min-height: 100vh;
}

/* Headlines use a slightly different stack but still system fonts */
h1, h2, h3, .font-display {
font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
font-weight: 700;
letter-spacing: -0.02em;
}

html { scroll-behavior: smooth; }

/* Header */
.header {
position: fixed;
top: 0;
left: 0;
right: 0;
z-index: 50;
background: rgba(9,16,33,0.95);
backdrop-filter: blur(12px);
border-bottom: 1px solid var(--nerd-border);
}

.header-content {
max-width: 1400px;
margin: 0 auto;
padding: 0 24px;
display: flex;
align-items: center;
justify-content: space-between;
height: 80px;
}

.header a { text-decoration: none; color: inherit; }

.logo {
display: flex;
align-items: center;
gap: 12px;
font-weight: 700;
font-size: 1.25rem;
}

.logo img {
width: 40px;
height: 40px;
border-radius: 8px;
background: var(--nerd-card);
border: 1px solid var(--nerd-border);
object-fit: cover;
}

.logo span { color: var(--accent); }

/* Desktop Navigation */
.nav-desktop { display: flex; gap: 32px; }
.nav-desktop a {
color: var(--nerd-muted);
text-decoration: none;
font-size: 0.875rem;
font-weight: 500;
transition: color 0.2s;
}
.nav-desktop a:hover { color: var(--nerd-text); }

/* Mobile Menu Button */
.mobile-btn {
display: none;
width: 44px;
height: 44px;
background: var(--nerd-card);
border: 1px solid var(--nerd-border);
border-radius: 8px;
color: var(--nerd-text);
font-size: 1.5rem;
cursor: pointer;
align-items: center;
justify-content: center;
margin-left: auto;
}

/* Mobile Menu Overlay */
.mobile-menu {
display: none;
position: fixed;
top: 0;
left: 0;
right: 0;
bottom: 0;
background: var(--nerd-bg);
z-index: 9999;
flex-direction: column;
justify-content: center;
align-items: center;
gap: 40px;
}

.mobile-menu.active { display: flex; }

.mobile-menu-close {
position: absolute;
top: 24px;
right: 24px;
width: 44px;
height: 44px;
background: var(--nerd-card);
border: 1px solid var(--nerd-border);
border-radius: 8px;
color: var(--nerd-text);
font-size: 1.5rem;
cursor: pointer;
}

.mobile-menu a {
color: var(--nerd-text);
font-size: 2rem;
font-weight: 700;
text-decoration: none;
}

/* Responsive */
@media (max-width: 767px) {
.nav-desktop { display: none !important; }
.mobile-btn { display: flex !important; }
body.menu-open { overflow: hidden; }
}

/* Animations */
@keyframes fadeInUp {
from { opacity: 0; transform: translateY(30px); }
to { opacity: 1; transform: translateY(0); }
}
@keyframes pulse {
0%, 100% { opacity: 1; }
50% { opacity: 0.5; }
}
.animate-in { animation: fadeInUp 0.8s ease forwards; opacity: 0; }
.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.3s; }

/* Sections */
section { padding: 120px 24px; }
.container { max-width: 1400px; margin: 0 auto; }
.text-center { text-align: center; }
.text-gradient {
background: linear-gradient(135deg, #fbfcfc 0%, var(--accent) 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
}

h1 { font-size: clamp(2.5rem, 8vw, 5rem); line-height: 1.1; margin-bottom: 24px; }
h2 { font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 48px; }

p { color: var(--nerd-muted); line-height: 1.8; }

/* Hero */
#hero {
min-height: 100vh;
display: flex;
align-items: center;
justify-content: center;
padding-top: 80px;
}

.badge {
display: inline-flex;
align-items: center;
gap: 8px;
padding: 8px 16px;
border-radius: 9999px;
background: var(--nerd-card);
border: 1px solid var(--nerd-border);
margin-bottom: 24px;
}

.badge span:first-child {
width: 8px;
height: 8px;
border-radius: 50%;
background: var(--accent);
animation: pulse 2s infinite;
}

.btn {
display: inline-flex;
align-items: center;
gap: 8px;
padding: 16px 32px;
border-radius: 9999px;
font-weight: 600;
text-decoration: none;
transition: all 0.2s;
cursor: pointer;
border: none;
font-size: 1rem;
}

.btn-primary {
background: var(--accent);
color: #fff;
}
.btn-primary:hover { filter: brightness(1.1); }

.btn-secondary {
background: var(--nerd-card);
border: 1px solid var(--nerd-border);
color: var(--nerd-text);
}
.btn-secondary:hover { border-color: var(--accent); }

.stats {
display: flex;
justify-content: center;
gap: 48px;
margin-top: 48px;
}
.stat { text-align: center; }
.stat-value {
font-size: 2rem;
font-weight: 700;
color: var(--accent);
}
.stat-label { font-size: 0.875rem; color: var(--nerd-muted); }

/* About */
.about-text { max-width: 650px; margin: 0 auto; font-size: 1.125rem; }

/* Setup Section */
#setup { background: rgba(13,22,41,0.5); }
.setup-card {
background: var(--nerd-card);
border: 1px solid var(--nerd-border);
border-radius: 24px;
padding: 32px;
margin-bottom: 24px;
max-width: 900px;
margin-left: auto;
margin-right: auto;
}
.setup-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
gap: 16px;
}
.setup-item {
padding: 16px;
background: rgba(9,16,33,0.5);
border-radius: 12px;
border: 1px solid var(--nerd-border);
}
.setup-item.highlight {
background: var(--accent);
color: var(--nerd-bg);
}

/* Contact */
#contact { background: rgba(13,22,41,0.5); }
.contact-box { max-width: 600px; margin: 0 auto; }

.icon-box {
width: 64px;
height: 64px;
border-radius: 50%;
background: var(--accent);
display: flex;
align-items: center;
justify-content: center;
margin: 0 auto 24px;
font-size: 1.75rem;
color: #fff;
}

/* Footer */
.footer {
padding: 48px 24px;
border-top: 1px solid var(--nerd-border);
background: rgba(13,22,41,0.5);
}
.footer-content {
display: flex;
flex-direction: column;
align-items: center;
gap: 24px;
}
@media (min-width: 768px) {
.footer-content { flex-direction: row; justify-content: space-between; }
}

.footer a { color: var(--nerd-muted); text-decoration: none; transition: color 0.2s; }
.footer a:hover { color: var(--nerd-text); }

/* Back to top */
#back-to-top {
position: fixed;
bottom: 24px;
right: 24px;
width: 48px;
height: 48px;
border-radius: 50%;
background: var(--accent);
color: #fff;
border: none;
cursor: pointer;
opacity: 0;
visibility: hidden;
transition: all 0.3s;
z-index: 100;
font-size: 1.25rem;
}
#back-to-top.visible { opacity: 1; visibility: visible; }
#back-to-top:hover { transform: translateY(-4px); background: var(--accent-hover); }

/* Scrollbar */
::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: var(--nerd-bg); }
::-webkit-scrollbar-thumb { background: var(--nerd-border); border-radius: 5px; }
::-webkit-scrollbar-thumb:hover { background: var(--accent); }

/* Focus */
:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
* { animation-duration:
