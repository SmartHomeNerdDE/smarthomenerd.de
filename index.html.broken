<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Home Nerd | Mach dein Zuhause smart. Wirklich smart.</title>
    <meta name="description" content="Tutorials, Reviews & Automationen für dein Smart Home. Home Assistant, Zigbee, DIY-Solutions.">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Tailwind Config mit Logo-Farben -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'nerd-bg': '#091021',
                        'nerd-card': '#0d1629',
                        'nerd-border': '#1a2847',
                        'nerd-light': '#162447',
                        'nerd-text': '#fbfcfc',
                        'nerd-muted': '#8b9bb3',
                        'accent': '#3b82f6',
                        'accent-hover': '#60a5fa',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Space Grotesk', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="css/style.css">
</head>
<body class="bg-nerd-bg text-nerd-text font-sans antialiased overflow-x-hidden">

<!-- ========================================= SUBTLE PARTICLE BACKGROUND ========================================= -->
<canvas id="particle-canvas" class="fixed inset-0 w-full h-full pointer-events-none z-0"></canvas>
<div class="fixed inset-0 w-full h-full bg-gradient-to-b from-nerd-bg via-transparent to-nerd-bg opacity-80 pointer-events-none z-[1]"></div>

    <!-- ========================================= NAVIGATION ========================================= -->
    <header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
        <div class="w-full px-4 sm:px-6 lg:px-8 xl:px-12">
            <div class="flex items-center justify-between h-20">
                <!-- Logo -->
                <a href="#" class="flex items-center gap-3 group">
                    <div class="w-10 h-10 rounded-lg bg-nerd-card border border-nerd-border flex items-center justify-center group-hover:border-accent transition-colors">
                        <img src="assets/images/logo-new.png" alt="Smart Home Nerd" class="w-full h-full object-cover">
                    </div>
                    <span class="font-display font-bold text-xl tracking-tight">
                        Smart Home <span class="text-accent">Nerd</span>
                    </span>
                </a>

                <!-- Desktop Navigation -->
                <nav class="hidden md:flex items-center gap-8">
                    <a href="#about" class="nav-link text-nerd-muted hover:text-nerd-text transition-colors text-sm font-medium">Über mich</a>
                    <a href="#videos" class="nav-link text-nerd-muted hover:text-nerd-text transition-colors text-sm font-medium">Videos</a>
                    <a href="#setup" class="nav-link text-nerd-muted hover:text-nerd-text transition-colors text-sm font-medium">Mein Setup</a>
                    <a href="#contact" class="nav-link text-nerd-muted hover:text-nerd-text transition-colors text-sm font-medium">Kontakt</a>
                </nav>

                <!-- CTA Button -->
                <div class="hidden md:block">
                    <a href="https://www.youtube.com/@SmartHomeNerd" target="_blank" class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent/10 border border-accent/30 rounded-full text-accent hover:bg-accent hover:text-nerd-bg transition-all duration-300 text-sm font-semibold group">
                        <i data-lucide="youtube" class="w-4 h-4"></i>
                        <span>Zum Kanal</span>
                    </a>
                </div>

                <!-- Mobile Menu Button -->
                <button id="mobile-menu-btn" class="md:hidden p-2 text-nerd-text" aria-label="Menu">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="md:hidden hidden bg-nerd-card/95 backdrop-blur-lg border-t border-nerd-border">
            <div class="px-4 py-6 space-y-4">
                <a href="#about" class="mobile-nav-link block text-nerd-muted hover:text-nerd-text transition-colors py-2 font-medium">Über mich</a>
                <a href="#videos" class="mobile-nav-link block text-nerd-muted hover:text-nerd-text transition-colors py-2 font-medium">Videos</a>
                <a href="#setup" class="mobile-nav-link block text-nerd-muted hover:text-nerd-text transition-colors py-2 font-medium">Mein Setup</a>
                <a href="#contact" class="mobile-nav-link block text-nerd-muted hover:text-nerd-text transition-colors py-2 font-medium">Kontakt</a>
                <div class="pt-4 border-t border-nerd-border">
                    <a href="https://www.youtube.com/@SmartHomeNerd" target="_blank" class="flex items-center gap-2 px-5 py-3 bg-accent text-nerd-bg rounded-lg font-semibold justify-center">
                        <i data-lucide="youtube" class="w-5 h-5"></i>
                        <span>Zum YouTube Kanal</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- ========================================= HERO-SECTION ========================================= -->
    <section id="hero" class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden">
        <!-- Background Grid -->
        <div class="absolute inset-0 bg-grid opacity-30"></div>
        
        <!-- Floating Circuit Lines Animation -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
            <div class="absolute top-1/4 left-10 w-px h-32 bg-gradient-to-b from-transparent via-accent/50 to-transparent animate-pulse"></div>
            <div class="absolute top-1/3 right-20 w-px h-48 bg-gradient-to-b from-transparent via-accent/30 to-transparent animate-pulse delay-300"></div>
            <div class="absolute bottom-1/4 left-1/4 w-24 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent animate-pulse delay-500"></div>
        </div>

        <!-- Content -->
        <div class="relative z-10 w-full px-4 sm:px-6 lg:px-8 xl:px-12">
            <div class="max-w-4xl mx-auto text-center">
                <!-- Badge -->
                <div class="hero-badge inline-flex items-center gap-2 px-4 py-2 rounded-full bg-nerd-card border border-nerd-border mb-8">
                    <i data-lucide="radio" class="w-4 h-4 text-accent animate-pulse"></i>
                    <span class="text-sm text-nerd-muted">YouTube-Kanal seit 2020</span>
                </div>

                <!-- Headline -->
                <h1 class="hero-headline font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold leading-tight mb-6">
                    <span class="block">Mach dein Zuhause</span>
                    <span class="block text-gradient mt-2">smart. Wirklich smart.</span>
                </h1>

                <!-- Subtitle -->
                <p class="hero-subtitle text-lg sm:text-xl text-nerd-muted max-w-2xl mx-auto mb-10 leading-relaxed">
                    Tutorials, Reviews & Automationen für dein Smart Home. Home Assistant, Zigbee, DIY-Solutions.</p>
</div>
</div>
</section>
</body>
</html>
